# SMTP credentials used by src/app/api/contact/route.ts to send lead notifications.
# Hostinger SMTP example shown — replace with your provider's values.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-smtp-password

# Inbox that receives new lead emails from the contact form.
CONTACT_TO=you@yourdomain.com
